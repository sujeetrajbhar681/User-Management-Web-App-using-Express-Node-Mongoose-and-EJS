<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Profiles</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
    <%- include('partials/navbar', { username: username }) %>
    <div class="container">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h3>Profiles</h3>
            <a href="/profiles/create" class="btn btn-success">+ Add Profile</a>
        </div>
        <div class="card shadow-sm">
            <div class="card-body">
                <table class="table table-hover align-middle">
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>Email</th>
                            <th>Age</th>
                            <th style="width:180px;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% profiles.forEach(p => { %>
                        <tr>
                            <td><%= p.name %></td>
                            <td><%= p.email %></td>
                            <td><%= p.age %></td>
                            <td>
                                <a href="/profiles/edit/<%= p._id %>" class="btn btn-sm btn-warning">Edit</a>
                                <form action="/profiles/delete/<%= p._id %>" method="POST" class="d-inline"
                                      onsubmit="return confirm('Delete this profile?');">
                                    <button type="submit" class="btn btn-sm btn-danger">Delete</button>
                                </form>
                            </td>
                        </tr>
                        <% }) %>
                        <% if (profiles.length === 0) { %>
                        <tr><td colspan="4" class="text-center text-muted">No profiles yet.</td></tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</body>
</html>